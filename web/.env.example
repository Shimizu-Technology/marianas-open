VITE_API_URL=http://localhost:3000

# ── Analytics (PostHog) ────────────────────────────────────────────────────
# Add these in local/prod env to enable analytics.
VITE_PUBLIC_POSTHOG_KEY=YOUR_POSTHOG_KEY
# US cloud (default): https://us.i.posthog.com
# EU cloud option:    https://eu.i.posthog.com
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── General Translation (GT) ──────────────────────────────────────────────
# Required for `npm run translate` to auto-translate locale files.
# Get keys at https://dash.generaltranslation.com
# Dev key (gtx-dev-*) for local development; Prod key (gtx-api-*) for CI/CD.
# GT_API_KEY=gtx-dev-your-dev-key
# GT_PROJECT_ID=your-project-id

# ── PDF Delivery ────────────────────────────────────────────────────────────
# URL for the downloadable SJJIF rules PDF shown on the Rules page.
# Leave unset (or empty) during local development — the site falls back to
# the bundled copy at /files/2018-sjjif-rulebook.pdf automatically.
#
# Once the compressed PDF has been uploaded to S3 (or another CDN), set this
# to the public object URL in your production environment file (.env.production
# or your hosting platform's env vars):
#
#   VITE_RULEBOOK_PDF_URL=https://your-bucket.s3.amazonaws.com/2018-sjjif-rulebook.pdf
#
# Compression workflow (when ready):
#   1. Run:  scripts/compress-pdf.sh  (see that file for details)
#   2. Upload the output file to S3:
#        aws s3 cp web/public/files/2018-sjjif-rulebook-compressed.pdf \
#                  s3://your-bucket/2018-sjjif-rulebook.pdf
#      (use bucket policy/CloudFront for public access; avoid legacy ACL flags)
#   3. Set VITE_RULEBOOK_PDF_URL in your production env and redeploy.
# VITE_RULEBOOK_PDF_URL=https://your-bucket.s3.amazonaws.com/2018-sjjif-rulebook.pdf
