{
  "$schema": "https://assets.gtx.dev/config-schema.json",
  "defaultLocale": "en",
  "locales": [
    "ja",
    "ko",
    "zh",
    "zh-Hant",
    "tl",
    "pt"
  ],
  "customMapping": {
    "tl": {
      "code": "fil",
      "name": "Filipino"
    }
  },
  "files": {
    "json": {
      "include": [
        "src/locales/[locale].json"
      ]
    }
  }
}